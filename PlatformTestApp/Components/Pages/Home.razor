@page "/"
@using Platform.SDK.Components.BibleComponents
@rendermode InteractiveServer

<PageTitle>YouVersion Bible Reader</PageTitle>

<div class="bible-reader-page">
    @if (HighlightsStatus == "denied")
    {
        <div class="alert alert-warning">Highlights access was not granted, so verse highlighting is unavailable.</div>
    }
    <BibleReader OAuthError="@OAuthError" EnableHighlighting="false" />
</div>

@code {
    [SupplyParameterFromQuery(Name = "oauth_error")]
    public string? OAuthError { get; set; }

    [SupplyParameterFromQuery(Name = "auth_mode")]
    public string? AuthMode { get; set; }

    [SupplyParameterFromQuery(Name = "highlights")]
    public string? HighlightsStatus { get; set; }
}
